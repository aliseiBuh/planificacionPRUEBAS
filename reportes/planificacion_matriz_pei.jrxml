		<parameter name="idPei" class="java.lang.Long"/>
		<queryString language="SQL">
			<![CDATA[select concat('AE',a.codigo) as area_estrategica,
       concat('PO',po.codigo) as codigo_politica,
       concat('POLITICA') as politica,
       po.descripcion as descripcion_politica from politica po
left join area a on po.id_area = a.id_area
left join pei p on a.id_pei = p.id_pei
where p.id_pei = $P{idPei} 
and po._estado != 'ELIMINADO']]>
		</queryString>
